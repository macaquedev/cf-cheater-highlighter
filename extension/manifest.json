{
  "manifest_version": 3,
  "name": "CF Cheater Highlighter",
  "version": "1.0.0",
  "description": "Highlights Codeforces handles marked as cheaters.",
  "permissions": [],
  "host_permissions": [
    "https://macaquedev.github.io/cf-cheater-highlighter/*"
  ],
  "background": {
    "service_worker": "background.js",
    "scripts": [
      "background.js"
    ]
  },
  "content_scripts": [
    {
      "matches": [
        "https://codeforces.com/*"
      ],
      "js": [
        "content-script.js"
      ],
      "css": [
        "styles.css"
      ]
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "{c044f723-1a1d-496c-a748-3646563acdd3}",
      "strict_min_version": "109.0",
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      }
    }
  }
}